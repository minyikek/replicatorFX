<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.replicatorfx.sbe"
                   id="1"
                   version="1"
                   semanticVersion="5.2"
                   description="FX Rates Simulator">

    <types>
        <composite name="messageHeader" description="Message identifiers and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId"  primitiveType="uint16"/>
            <type name="schemaId"    primitiveType="uint16"/>
            <type name="version"     primitiveType="uint16"/>
        </composite>

        <composite name="groupSizeEncoding" description="Encoding of group dimensions">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup" primitiveType="uint16"/>
        </composite>

        <composite name="varStringEncoding" description="Variable-length UTF-8 string">
            <type name="length"  primitiveType="uint16" maxValue="65534"/>
            <type name="varData" primitiveType="uint8"  length="0" characterEncoding="UTF-8"/>
        </composite>

        <enum name="BooleanType" encodingType="uint8">
            <validValue name="FALSE">0</validValue>
            <validValue name="TRUE">1</validValue>
        </enum>

        <!-- fixed-length character arrays -->
        <type name="instrument10" primitiveType="char" length="10" characterEncoding="US-ASCII"/>
        <type name="char7"        primitiveType="char" length="7"  characterEncoding="US-ASCII"/>
    </types>

    <sbe:message name="OrderBookSnapshot" id="6" description="Order Book Snapshot">
        <field name="seqId"               id="1"  type="uint64"/>
        <field name="sendingTime"         id="2"  type="uint64"/>
        <field name="processTime"         id="3"  type="uint64"/>
        <field name="instrument"          id="4"  type="instrument10"/>
        <field name="tenor"               id="5"  type="instrument10"/>
        <field name="forward"             id="6"  type="BooleanType"/>
        <field name="ccyPair"             id="7"  type="char7"/>
        <field name="lastUpdateTimeStamp" id="8"  type="uint64"/>
        <field name="isModifiedByInvoke"  id="9"  type="BooleanType"/>
        <field name="pipSize"             id="30" type="double"/>

        <group name="bids" id="10" dimensionType="groupSizeEncoding">
            <field name="price"     id="11" type="double"/>
            <field name="size"      id="12" type="double"/>
            <field name="tradeable" id="13" type="BooleanType"/>
            <data  name="valueDate" id="14" type="varStringEncoding"/>
            <data  name="lpName"    id="15" type="varStringEncoding"/>
            <data  name="entryId"   id="16" type="varStringEncoding"/>
        </group>

        <group name="asks" id="17" dimensionType="groupSizeEncoding">
            <field name="price"     id="18" type="double"/>
            <field name="size"      id="19" type="double"/>
            <field name="tradeable" id="20" type="BooleanType"/>
            <data  name="valueDate" id="21" type="varStringEncoding"/>
            <data  name="lpName"    id="22" type="varStringEncoding"/>
            <data  name="entryId"   id="23" type="varStringEncoding"/>
        </group>

        <data name="fixSession"    id="24" type="varStringEncoding"/>
        <data name="takerCompID"   id="25" type="varStringEncoding"/>
        <data name="senderCompID"  id="26" type="varStringEncoding"/>
        <data name="sourceSystem"  id="27" type="varStringEncoding"/>
        <data name="valueDate"     id="28" type="varStringEncoding"/>
        <data name="traceId"       id="29" type="varStringEncoding"/>
    </sbe:message>

</sbe:messageSchema>
